{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "background": "#ff0044",
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": " \uf489 {{ .Name }} ",
          "type": "shell"
        },
        {
          "background": "#0000ff",
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b0",
          "style": "diamond",
          "template": " <#44ff44>\ue266</> RAM: {{ round .PhysicalPercentUsed .Precision }}% | {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB <#44ff44>\ue266</>  ",
          "type": "sysinfo"
        },
        {
          "options": {
            "branch_icon": "\uf418 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "git_icon": "\uf02a2",
            "github_icon": "\uf408 "
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#00ff00",
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffbe0b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f26d50{{ end }}",
            "{{ if gt .Ahead 0 }}#89d1dc{{ end }}",
            "{{ if gt .Behind 0 }}#f17c37{{ end }}"
          ]
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "options": {
            "time_format": "03:04 PM"
          },
          "style": "plain",
          "template": " <#ff0000>\uf4e1</> {{ .CurrentDate | date .Format }} |",
          "type": "time"
        },
        {
          "style": "plain",
          "template": " \uf292 ",
          "type": "root"
        },
        {
          "options": {
            "cache_duration": "none",
            "display_default": true,
            "display_mode": "always",
            "folder_name_fallback": false
          },
          "template": "{{ if not .Error }} <#44AAFF>\ue235</> {{ if .Venv }}{{ .Venv }}{{ else }}{{ .Full }}{{ end }} {{ end }}|",
          "type": "python",
          "style": "plain"
        },
        {
          "options": {
            "folder_icon": "<#FFEE44>\ue5fe </>",
            "folder_separator_icon": "/",
            "home_icon": "<#0078D7>\uf015 </>"
          },
          "style": "plain",
          "template": " <#FFEE44>\uef81 </> {{ .Path }}",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u2570\u2500 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{.UserName}}@{{.HostName}}",
  "version": 4
}