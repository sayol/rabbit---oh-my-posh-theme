{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "\uE0B2",
          "background": "#FF0044",
          "foreground": "#FFFFFF",
          "template": " {{ .Icon }} OS "
        },
        {
          "background": "#0000ff",
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b0",
          "style": "diamond",
          "template": " <#44ff44>\ue266</> RAM: {{ round .PhysicalPercentUsed .Precision }}% <#44ff44>\ue266</>  ",
          "type": "sysinfo"
        },
        {
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "git_icon": "\ue702 ",
            "github_icon": "\uf408 ",
            "branch_icon": "\uf418 "
          },
          "template": " {{ if .UpstreamIcon }}{{ .UpstreamIcon }}{{ end }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#00ff00",
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ffbe0b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f26d50{{ end }}",
            "{{ if gt .Ahead 0 }}#89d1dc{{ end }}",
            "{{ if gt .Behind 0 }}#f17c37{{ end }}"
          ]
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#ffffff",
          "template": " \uf252 {{ .FormattedMs }} ",
          "options": {
            "always_enabled": true,
            "style": "roundrock",
            "threshold": 0
          }
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "style": "plain",
          "foreground": "#FFFFFF",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "foreground": "#ffffff",
          "leading_diamond": "\ue0b2",
          "style": "plain",
          "template": " \uf489 {{ .Name }}",
          "type": "shell"
        },
        {
          "type": "python",
          "style": "plain",
          "options": {
            "cache_duration": "none",
            "display_default": true,
            "display_mode": "always",
            "folder_name_fallback": false
          },
          "foreground": "#FFFFFF",
          "template": "{{ if not .Error }} <#44AAFF>\ue235</> {{ if .Venv }}{{ .Venv }}{{ else }}{{ .Full }}{{ end }} {{ end }}"
        },
        {
          "options": {
            "folder_icon": "<#FFEE44>\ue5fe </>",
            "folder_separator_icon": "/",
            "home_icon": "<#44AAFF>\uf015 </>"
          },
          "style": "plain",
          "foreground": "#FFFFFF",
          "template": "<#FFEE44>\uef81 </> {{ .Path }}",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "foreground": "#FFFFFF",
          "template": "\u2570\u2500 ",
          "type": "status"
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "#FFFFFF",
          "template": "{{ if .Root }}<#44AAFF>\udb81\udc83</>{{ else }}<#FFFFFF>\uf007</>{{ end }} ",
          "options": {
            "root_icon": "\udb81\udc83",
            "display_mode": "always"
          }
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{.UserName}}@{{.HostName}}",
  "version": 4
}